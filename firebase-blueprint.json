{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with roles and workspace membership.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "leader", "member"] },
        "workspaceId": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "workspaceId"]
    },
    "Workspace": {
      "title": "Workspace",
      "description": "A workspace representing an organization or team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdBy", "createdAt"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A channel representing a specific project or topic within a workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "assignedLeaderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "workspaceId", "name", "isArchived", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task created within a channel and assigned to a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "channelId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedUserId": { "type": "string" },
        "creatorId": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "inprogress", "review", "completed"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "workspaceId", "channelId", "title", "creatorId", "priority", "status", "createdAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A discussion update or task update comment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "channelId": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "workspaceId", "userId", "userName", "content", "createdAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "An action log of events in the workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "workspaceId", "userId", "userName", "action", "details", "createdAt"]
    }
  },
  "firestore": {
    "/workspaces/{workspaceId}": {
      "schema": { "$ref": "#/entities/Workspace" },
      "description": "Workspaces collection"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection with role metadata"
    },
    "/workspaces/{workspaceId}/channels/{channelId}": {
      "schema": { "$ref": "#/entities/Channel" },
      "description": "Channels nested under workspace"
    },
    "/workspaces/{workspaceId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks nested under workspace"
    },
    "/workspaces/{workspaceId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments nested under workspace for speed query"
    },
    "/workspaces/{workspaceId}/logs/{logId}": {
      "schema": { "$ref": "#/entities/ActivityLog" },
      "description": "Activity logs nested under workspace"
    }
  }
}
