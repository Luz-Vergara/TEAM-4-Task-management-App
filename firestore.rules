rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow user profile operations
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Allow workspace level read/writes
    match /workspaces/{workspaceId} {
      allow get: if true; // Allow anyone to check if a workspace exists and verify its join code
      allow list, write: if isAuthenticated();

      // Nested collections under workspace
      match /channels/{channelId} {
        allow read, write: if isAuthenticated();
      }

      match /tasks/{taskId} {
        allow read, write: if isAuthenticated();
      }

      match /comments/{commentId} {
        allow read, write: if isAuthenticated();
      }

      match /logs/{logId} {
        allow read, write: if isAuthenticated();
      }

      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
